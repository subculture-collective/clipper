# Frontend Production Environment (Example)
#
# ⚠️  Frontend .env files are bundled into the build!
#     Only include NON-SECRET, PUBLIC configuration here.
#
# Production Build:
#   - Values are embedded at build time (docker build)
#   - Use build args or CI/CD secrets injection for environment-specific values
#   - Never include API keys or secrets (use backend proxy instead)

# API Configuration (public)
VITE_API_BASE_URL=https://clpr.tv/api/v1
VITE_BASE_URL=https://clpr.tv

# Twitch OAuth (public client ID only, no secret)
VITE_TWITCH_CLIENT_ID=your_twitch_client_id_here

# Feature Flags (public)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# Stripe (publishable key only, safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
VITE_STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_your_yearly_price_id

# Sentry (public DSN, safe to expose)
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=https://public_dsn@sentry.io/project_id
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=v1.0.0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
