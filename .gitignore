backend/.env.local

# Frontend environment files (use build-time injection in production)
frontend/.env
frontend/.env.production
frontend/.env.local

# Legacy file-based secrets directory (replaced by Vault)
secrets/

# Vault credentials and rendered secrets (never commit)
vault/approle/role_id
vault/approle/secret_id
vault/rendered/backend.env
vault/rendered/*.env

