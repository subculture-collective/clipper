# Backend Production Environment (Example)
# 
# ⚠️  DO NOT commit actual secrets to version control!
# 
# Production Setup:
#   1. Vault injects secrets via agent template (see vault/templates/backend.env.ctmpl)
#   2. Secrets rendered to /vault/secrets/backend.env at runtime
#   3. Backend sources this file on startup (see docker-compose.prod.yml)
#
# Local Development:
#   Copy backend/.env.example and populate with development credentials

# Server Configuration
PORT=8080
GIN_MODE=release
BASE_URL=https://clpr.tv
ENVIRONMENT=production
LOG_LEVEL=info

# Database (managed by Vault in production)
DB_HOST=postgres
DB_PORT=5432
DB_USER=clipper
DB_NAME=clipper_db
DB_SSLMODE=require
# DB_PASSWORD injected by Vault

# Redis (managed by Vault in production)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD injected by Vault

# JWT Keys (managed by Vault in production)
# JWT_PRIVATE_KEY injected by Vault
# JWT_PUBLIC_KEY injected by Vault

# Twitch OAuth (managed by Vault in production)
# TWITCH_CLIENT_ID injected by Vault
# TWITCH_CLIENT_SECRET injected by Vault
TWITCH_REDIRECT_URI=https://clpr.tv/api/v1/auth/twitch/callback

# CORS
CORS_ALLOWED_ORIGINS=https://clpr.tv

# OpenSearch (managed by Vault in production)
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INSECURE_SKIP_VERIFY=false
# OPENSEARCH_USERNAME injected by Vault
# OPENSEARCH_PASSWORD injected by Vault

# Stripe (managed by Vault in production)
# STRIPE_SECRET_KEY injected by Vault
# STRIPE_WEBHOOK_SECRET injected by Vault
STRIPE_SUCCESS_URL=https://clpr.tv/subscription/success
STRIPE_CANCEL_URL=https://clpr.tv/subscription/cancel
# STRIPE_PRO_MONTHLY_PRICE_ID injected by Vault
# STRIPE_PRO_YEARLY_PRICE_ID injected by Vault

# Sentry
SENTRY_ENABLED=false
# SENTRY_DSN injected by Vault (if enabled)
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Email via SendGrid (managed by Vault in production)
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS=noreply@clpr.tv
EMAIL_FROM_NAME=Clipper
EMAIL_MAX_PER_HOUR=10
# SENDGRID_API_KEY injected by Vault (if enabled)

# OpenAI Embeddings (managed by Vault in production)
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_REQUESTS_PER_MINUTE=500
EMBEDDING_SCHEDULER_INTERVAL_MINUTES=360
# OPENAI_API_KEY injected by Vault (if enabled)

# Feature Flags
FEATURE_SEMANTIC_SEARCH=false
FEATURE_PREMIUM_SUBSCRIPTIONS=false
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_ANALYTICS=true
FEATURE_MODERATION=true
FEATURE_DISCOVERY_LISTS=false

# Background Job Intervals
HOT_CLIPS_REFRESH_INTERVAL_MINUTES=5
WEBHOOK_RETRY_INTERVAL_MINUTES=1
WEBHOOK_RETRY_BATCH_SIZE=100
